{
  "installCommand": "yarn install",
  "buildCommand": "yarn build",
  "devCommand": "yarn dev",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/event-reminders",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/event-reminders-morning",
      "schedule": "0 10 * * *"
    }
  ]
}
